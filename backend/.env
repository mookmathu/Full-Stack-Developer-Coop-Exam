# Database 
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=1234
DB_NAME=fleet_db

# JWT Secrets (เปลี่ยนเป็น random string ยาวๆ ก่อน deploy)
JWT_SECRET=fleet_jwt_secret_change_this_in_production_2024
JWT_REFRESH_SECRET=fleet_refresh_secret_change_this_in_production_2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500

